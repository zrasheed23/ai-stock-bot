ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic — LLM used only for summaries / sentiment / risk flags (not orders)
ANTHROPIC_API_KEY=

# Finnhub — optional; company news for the watchlist (https://finnhub.io/register)
FINNHUB_API_KEY=

# Optional: path to kill-switch file (create empty file or write "1" to halt trading)
STOCKBOT_KILL_SWITCH_PATH=./var/kill_switch

# Optional: persist daily state (one trade per day, etc.)
STOCKBOT_STATE_DIR=./var/state

# Optional: audit output root
STOCKBOT_AUDIT_DIR=./var/audit

# When true/1/yes/on, market ingestion never substitutes synthetic OHLC (backtest_runner sets this during runs).
STOCKBOT_REQUIRE_REAL_MARKET=
